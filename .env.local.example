# ── EmailJS (contact form) ──────────────────────────────────────────
# Create a free account at https://www.emailjs.com/ then fill in the
# three values below.
#
# NEXT_PUBLIC_EMAILJS_SERVICE_ID
#   Dashboard → "Email Services" → select your service → copy the Service ID
#
# NEXT_PUBLIC_EMAILJS_TEMPLATE_ID
#   Dashboard → "Email Templates" → select your template → copy the Template ID
#
# NEXT_PUBLIC_EMAILJS_PUBLIC_KEY
#   Dashboard → "Account" → "General" tab → "Public Key" section
#   (This was previously called "User ID" in older EmailJS versions.)
# ────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_xxxxxx
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_xxxxxx
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxx
